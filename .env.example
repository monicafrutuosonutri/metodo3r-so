# Auroq OS — Variaveis de Ambiente
# Copie este arquivo para .env e preencha com seus dados

# Supabase (se usar banco de dados)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY=

# Meta Marketing API (se usar trafego pago)
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=

# ManyChat (se usar WhatsApp automation)
# MANYCHAT_API_KEY=

# Hotmart (se usar como plataforma de vendas)
# HOTMART_CLIENT_ID=
# HOTMART_CLIENT_SECRET=

# N8N (se usar automacoes)
# N8N_BASE_URL=
# N8N_API_KEY=
